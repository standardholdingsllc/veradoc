{
  "schema_name": "veradoc_transparent_logo_reproduction_spec",
  "schema_version": "2.0-clean-vector",
  "brand": "VeraDoc.pe",
  "asset_name": "VeraDoc feather over water icon",
  "purpose": "Create a transparent-background version of the uploaded VeraDoc icon without jagged, stair-stepped, white-fringed, or pixelated edges.",
  "source_files": {
    "original_soft_background_png": {
      "path_hint": "veradoc-icon-soft-bg-1024.png",
      "size_px": [
        1024,
        1024
      ],
      "sha256": "88e869b7f2c6fff0d20ecf53a75feef2f00f73c9bd6e7c010027c8bd6a3a624c",
      "background_color_sample": {
        "hex": "#F5FAFC",
        "rgb": [
          245,
          250,
          252
        ]
      }
    },
    "rejected_previous_transparent_output": {
      "path_hint": "veradoc-icon-transparent-background-1024.png",
      "sha256": "d76e98280745d10f60b3bbfcb02b4f1b73c81cf2cdf1a3bd8c65d573abc9a011",
      "status": "rejected because edge pixels retained off-white matte/fringe and the silhouette was raster-derived."
    },
    "dark_background_failure_preview": {
      "path_hint": "user-provided dark preview screenshot",
      "sha256": "da4efa0a4c0972159686a23dca894a16c521d322f6c612597f5472448d1463a0",
      "status": "shows the defect clearly: light halo and jagged raster stair-stepping on black."
    }
  },
  "root_cause_analysis": {
    "summary": "The unacceptable edge quality is not caused by the dark background. The dark background only reveals errors introduced by the transparent-background conversion.",
    "causes": [
      {
        "id": "matte_contamination",
        "problem": "The source icon was anti-aliased against a soft off-white background (#F5FAFC). A background-removal pass treated near-background pixels as semi-transparent but left their RGB values close to the original off-white matte. On a black background those pixels render as pale gray/white fringe around the logo.",
        "visible_symptom": "White or gray outline around the feather and waves, especially along the diagonal outer feather edge and central vein."
      },
      {
        "id": "raster_mask_thresholding",
        "problem": "The previous JSON allowed a pixel-distance threshold/ramp against #F5FAFC. That creates an alpha mask from the 1024px raster source. Any slight threshold mistake turns antialiasing into a hard, uneven stair-step mask.",
        "visible_symptom": "Edges look chipped and pixelated instead of smooth."
      },
      {
        "id": "integer_polygon_trace",
        "problem": "The previous path was an auto-traced bitmap contour made primarily of integer-coordinate straight line segments. Curved feather edges were approximated as many tiny line segments instead of true cubic B\u00e9zier curves.",
        "visible_symptom": "Diagonal curves become visibly angular when composited on high-contrast backgrounds."
      },
      {
        "id": "wrong_output_priority",
        "problem": "The spec described a transparent PNG target but did not make SVG/vector reconstruction mandatory. Agents could legally perform a cleaned raster extraction, which is unsuitable for a logo that must work over dark UI backgrounds.",
        "visible_symptom": "The image may look acceptable over off-white, but fails on black, charcoal, navy, or transparent app surfaces."
      }
    ],
    "required_fix": "Do not re-key the background from the raster as the final asset. Rebuild the mark as clean vector paths on a transparent canvas, render with normal vector antialiasing, and export PNGs from the vector source at high resolution."
  },
  "non_negotiable_rendering_rules": {
    "background": {
      "must_be": "fully transparent",
      "must_not_include": [
        "white rectangle",
        "off-white #F5FAFC rectangle",
        "gray app-icon tile",
        "dark preview background",
        "checkerboard baked into the file"
      ]
    },
    "vector_first": {
      "mandatory": true,
      "rule": "Final master asset must be SVG or equivalent vector geometry. PNG output must be rendered from the vector master, not from a keyed raster cutout.",
      "forbidden": [
        "hard threshold background removal as final output",
        "magic-wand selection as final output",
        "nearest-neighbor upscaling",
        "shape-rendering='crispEdges'",
        "integer-only polygon trace as final master",
        "1px white/gray stroke to hide roughness",
        "drop shadow or glow to conceal fringe"
      ]
    },
    "antialiasing": {
      "must_use": "renderer-generated subpixel antialiasing from vector geometry",
      "recommended_export": "Render SVG at 4096x4096 or 8192x8192, then downsample to 1024x1024 using Lanczos if a PNG is needed.",
      "edge_rgb_rule": "Transparent or semi-transparent edge pixels must be colored from the logo foreground, not from the removed #F5FAFC matte."
    },
    "negative_space": {
      "central_vein": "transparent cut-through, not white paint",
      "feather_notches": "transparent cut-throughs, not white paint",
      "gaps_between_waves": "transparent gaps, not white paint"
    }
  },
