  "png_export_instructions": {
    "master": "Use svg_master_template as the source of truth.",
    "transparent_png_1024": [
      "Render SVG to 4096x4096 or higher with transparent background.",
      "Downsample to 1024x1024 using Lanczos/resampling intended for photographic/vector antialiasing.",
      "Export as PNG-24 with alpha channel.",
      "Do not flatten, matte, or premultiply against white, #F5FAFC, black, or any UI color."
    ],
    "transparent_png_512": [
      "Render from SVG directly at 2048x2048 or 4096x4096.",
      "Downsample to 512x512 using Lanczos.",
      "Do not resize the already-exported 1024 raster with nearest-neighbor or bilinear."
    ],
    "favicon_or_small_icon": [
      "For sizes below 128px, render directly from SVG. Do not use the old raster extraction.",
      "Consider slightly simplifying wave detail only if required for legibility, but do not add a background."
    ]
  },
  "validation_tests": {
    "visual_tests": [
      "Place final PNG over #000000. No white/gray halo may appear.",
      "Place final PNG over #111111. Edges must remain smooth, with no stair-step outline.",
      "Place final PNG over #0F172A navy/ink. The central feather vein and wave gaps must show the background cleanly.",
      "Place final PNG over checkerboard. There must be no hidden square, rectangle, or off-white matte."
    ],
    "pixel_tests_for_png_outputs": [
      {
        "name": "transparent_canvas_corners",
        "rule": "Pixels at (0,0), (1023,0), (0,1023), and (1023,1023) must have alpha 0."
      },
      {
        "name": "no_soft_background_matte",
        "rule": "No pixel with alpha > 0 may have RGB within 8 Euclidean units of #F5FAFC, except if it is intentionally part of a cyan wave highlight; this logo contains no white foreground."
      },
      {
        "name": "edge_fringe_fail_condition",
        "rule": "Fail if more than 0.1% of semi-transparent edge pixels, defined as 1 <= alpha <= 250, are closer to #F5FAFC than to the nearest declared foreground palette color."
      },
      {
        "name": "antialias_presence",
        "rule": "A valid PNG should contain semi-transparent alpha values at curved edges after vector rendering; alpha should not be only 0 and 255."
      }
    ],
    "geometry_tests": [
      "Visible non-transparent bounding box should be approximately x=313..721, y=215..810 on a 1024 canvas.",
      "The feather tip should terminate near (715,215).",
      "The lower wave cluster should terminate near x=602 and y=810.",
      "The logo must remain visually centered around x=517, y=512."
    ]
  },
  "agent_prompt": {
    "title": "Create clean VeraDoc transparent logo from vector spec",
    "instructions": "Use the SVG master template and path data in this JSON as the source of truth. Do not perform bitmap background removal as the final output. Produce a transparent SVG and transparent PNG exports. The old #F5FAFC source background is not a color in the final asset; it must be fully transparent. The central feather vein, feather side cuts, and spaces between the waves must be transparent negative space, not white fills. Render from vector at high resolution and downsample with high-quality antialiasing. Validate on black, charcoal, navy, and checkerboard backgrounds before returning the asset."
  },
